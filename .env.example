# 360° Data Athlete — environment template
#
# Copy to `.env` and fill the keys you need.
#
# The "Alex Demo" profile bundled in config.example/ can be loaded
# read-only with no credentials at all. For an actual training workflow
# (planning, pushing workouts, fetching wellness), intervals.icu is
# effectively required.
#
# Labels per block:
#   REQUIRED  — needed for the listed feature to work at all
#   OPTIONAL  — feature degrades gracefully without it
#   DEV-ONLY  — tracing / debugging, not needed in normal use

# ─────── intervals.icu ─────────────────────────────────────────────────────
# REQUIRED for: planner pushing workouts, fetching wellness / activities,
# /training, /analyse, /wellness, post-activity NOTEs.
# Without these the Alex Demo still loads, but no live data flows.
INTERVALS_ICU_API_KEY=
INTERVALS_ICU_ATHLETE_ID=

# ─────── Shoe tracking ─────────────────────────────────────────────────────
# Source of truth for shoe data (gear list, mileage, active/retired) feeding
# the shoe advisor:
#   intervals (default) — native intervals.icu gear; mileage accumulates from
#                         each activity's gear_id. No Strava app needed.
#   strava (legacy)     — Strava gear API + text recommendation footer.
#                         Requires the STRAVA_* credentials below.
#   off                 — shoe advisor disabled.
# One-time migration of an existing Strava fleet:
#   python3 scripts/migrate_shoes_strava_to_intervals.py --apply
SHOE_TRACKING_BACKEND=intervals

# ─────── Strava ────────────────────────────────────────────────────────────
# OPTIONAL — needed for: SHOE_TRACKING_BACKEND=strava, Strava title sync,
# and the one-time shoe migration script.
# Run `python3 scripts/strava_auth.py` once to obtain a refresh token.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
# Master on/off switch for the Strava title/insights publishing feature.
# Default `false`: Strava has moved activity writes behind its updated
# developer-program access, so `PUT /activities/{id}` returns 403 Forbidden
# for apps without the `activity:write` scope — independent of your own
# Strava subscription. While disabled, `/strava` and `/analyse` step 6.6
# short-circuit cleanly (no Strava call, no 403). Set to `true` only once
# your Strava app actually holds write access.
STRAVA_PUBLISH_ENABLED=false
# strava-publisher: on/off toggle for the follower-facing insights block
# (2–4 lines of curated form/HR/pace insight + a random-gerund footer
# line). Default `true` — every endurance push gets the block, the
# footer also acts as the re-run idempotency anchor. Set to `false` if
# you only want title sync and no signature on your Strava feed; the
# agent then skips the body and the footer entirely.
STRAVA_PUBLISHER_FOOTER_ENABLED=true
# Suffix appended after the random gerund in the Strava insights footer
# (when enabled). Default `by 360° Data Athlete` is the project brand
# and acts as light open-source attribution on follower feeds. Override
# to brand activities with your own coach signature, e.g.
# `STRAVA_PUBLISHER_FOOTER_SUFFIX=by My Coach`, or set
# `STRAVA_PUBLISHER_FOOTER_ENABLED=false` above to disable the block
# entirely.
STRAVA_PUBLISHER_FOOTER_SUFFIX=by 360° Data Athlete

# ─────── Garmin ────────────────────────────────────────────────────────────
# OPTIONAL — needed for: FIT-file download (running dynamics, video
# form check). intervals.icu alone is enough for planning / lap chronicle.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# ─────── Telegram plugin ───────────────────────────────────────────────────
# OPTIONAL — needed for the official Telegram plugin (chat from the phone).
TELEGRAM_BOT_ACCESS_TOKEN=
# Comma-separated list of chat IDs that are allowed to talk to the bot.
TELEGRAM_ALLOWED_USER_IDS=
# Convenience: where to send messages when there's only one chat.
TELEGRAM_CHAT_ID=

# ─────── LLM providers ─────────────────────────────────────────────────────
# REQUIRED for: video form check (`scripts/analyse_video.py`, calls
# Gemini through OpenRouter) and for any planner/specialist prompt
# whose YAML metadata names an OpenRouter model.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.1-pro-preview
# `X-Title` header surfaced on the OpenRouter account dashboard. Override
# to label your usage with the wrapper / consumer app name.
OPENROUTER_X_TITLE=aicoach-framework

# ─────── LangSmith tracing ─────────────────────────────────────────────────
# DEV-ONLY — enables LangChain / LangSmith trace export. Disabled by
# default in production.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai_coach_dev

# ─────── Container / runtime overrides ─────────────────────────────────────
# OPTIONAL — set only if you run a wrapper repo or container setup.
#
# COACH_HOME            — root of the athlete wrapper repo
#                         (defaults to framework root)
# CONFIG_DIR            — override config search directory
# DATA_DIR              — override data directory (muscles, audits)
# CACHE_DIR             — override cache directory
# TELEGRAM_PLUGIN_ENV_PATH — path to a separate Telegram-plugin .env file
#                            (consumed by app/utils/alerts.py). When unset,
#                            the resolver skips the plugin file and falls back
#                            to TELEGRAM_BOT_ACCESS_TOKEN via pydantic-settings.
#                            No default path is assumed — wrappers that ship
#                            a Telegram integration at a fixed location must
#                            set this explicitly.
#
# Wrapper-specific infrastructure (private Git remotes, VLAN routing,
# iptables defense-in-depth, auto-pull) is handled by the consumer's
# wrapper entrypoint, not by the framework itself. See the wrapper's
# entrypoint.sh for the corresponding ENV variables.
COACH_HOME=
